! https://xcolors.herokuapp.com/dl/neon

*background 		: #171717
*foreground 		: #c6c6c6

! black
*color0  			: #171717
*color8  			: #38252C
! red
*color1  			: #D81765
*color9  			: #FF0000
! green
*color2  			: #97D01A
*color10 			: #76B639
! yellow
*color3  			: #FFA800
*color11 			: #E1A126
! blue
*color4  			: #16B1FB
*color12 			: #289CD5
! magenta
*color5  			: #FF2491
*color13 			: #FF2491
! cyan
*color6  			: #0FDCB6
*color14 			: #0A9B81
! white
*color7  			: #EBEBEB
*color15 			: #F8F8F8

*alpha: 0.95

*font:	monospace:pixelsize=13:antialias=true:autohint=true;
URxvt*font: xft:monospace:size=8
URxvt*scrollBar: false
URxvt*url-launcher: /usr/bin/xdg-open

Xft.dpi: 164
Xft.antialias: true
Xft.hinting: true
Xft.rgba: rgb
Xft.autohint: false
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault

urxvt.perl-ext-common:  resize-font
URxvt.keysym.C-Down:    resize-font:smaller
URxvt.keysym.C-Up:      resize-font:bigger
