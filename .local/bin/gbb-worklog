#!/usr/bin/python
import calendar
import datetime
import getpass
import json
import os

try:
    from dateutil import parser
except:
    print('Install dateutils: "sudo pip install python-dateutil"')
    exit(-1)

import requests
from requests.auth import HTTPBasicAuth

try:
    input = raw_input
except NameError:
    pass


def jira(url): return "https://soci80.atlassian.net{}".format(url)


def get_issue(issue_id):
    r = requests.get(jira("/rest/api/2/issue/{}".format(issue_id)), auth=auth)
    assert r.status_code == 200
    return json.loads(r.text)


def get_worklogs(since):
    r = requests.get(jira("/rest/api/2/worklog/updated?since={}".format(since)), auth=auth)
    assert r.status_code == 200
    d = json.loads(r.text)
    ids = {"ids": [w['worklogId'] for w in d['values']]}
    d = json.dumps(ids)
    r = requests.post(
        jira("/rest/api/2/worklog/list".format(since)),
        auth=auth,
        headers={
            "Accept": "application/json",
            "Content-Type": "application/json"
        },
        data=d)
    assert r.status_code == 200
    return json.loads(r.text)


def manual_user():
    userfile = '/tmp/jira_worklog_user'

    if not os.path.exists(userfile):
        username = input('Enter username (not email address): ')
        with open(userfile, 'w') as f:
            f.write(username)
    else:
        with open(userfile) as f:
            username = f.readline()
            print('Enter username: {} (from file \'{}\')'.format(username, userfile))
    password = getpass.getpass('Enter password: ')
    return username, password


username = os.environ.get("JIRA_USER")
password = os.environ.get("JIRA_PASS")

if username is None:
    username, password = manual_user()

auth = HTTPBasicAuth(username, password)


def manual_choice():
    print("Select timerange to fetch worklog:")
    print("1) Today")
    print("2) This week")
    print("3) This week and last week")
    return input("Choice: ")


choice = os.environ.get("JIRA_CHOICE")

if choice is None:
    choice = manual_choice()

choice = int(choice)

if choice == 1:
    timestamp = datetime.datetime.combine(datetime.datetime.today(), datetime.time.min)
elif choice == 2:
    timestamp = datetime.date.today()
    timestamp -= datetime.timedelta(days=-(timestamp.weekday() - 1), weeks=1)
elif choice == 3:
    timestamp = datetime.date.today()
    timestamp -= datetime.timedelta(days=-(timestamp.weekday() - 1), weeks=1)
    timestamp += datetime.timedelta(days=-7)
else:
    print("Bad selection")
    exit(-1)

timestamp = int(timestamp.strftime("%s")) * 1000

worklogs = get_worklogs(timestamp)
worklogs = [w for w in worklogs if w['author']['name'] == username]

cleaned = []
for w in worklogs:
    issue = get_issue(w['issueId'])
    cleaned.append({
        'started': parser.parse(w['started']),
        'issue': "{} {} ({})".format(issue['key'], issue['fields']['summary'], jira("/browse/{}".format(issue['key']))),
        'timeSpent': w['timeSpent'],
        'timeSpentSeconds': w['timeSpentSeconds'],
        'comment': w.get('comment', '<NO COMMENT>')
    })

cleaned = sorted(cleaned, key=lambda x: x['started'])

print()

totalSeconds = 0

weekday = None
totalSecondsDay = None


def get_time_worked(seconds):
    t_hours = int(seconds / 3600)
    t_minutes = int((seconds - (t_hours * 3600)) / 60)
    return t_hours, t_minutes


colors = {
    0: '\033[1m\033[96m',
    1: '\033[1m\033[92m',
    2: '\033[1m\033[94m',
    3: '\033[1m\033[93m',
    4: '\033[1m\033[95m',
    5: '\033[1m\033[97m',
    6: '\033[1m\033[91m',
    'CL': '\033[0m'
}


def print_day(w, t):
    print("---{} {} {} {}---".format(
        colors[w], calendar.day_name[w],
        t.strftime("%Y-%m-%d"),
        colors['CL'])
    )


def print_logged_that_day(w, s):
    h, m = get_time_worked(s)
    print("")
    print("---{} Total time logged that day: {}h {}m {}---".format(colors[w], h, m, colors['CL']))
    print("")


for w in cleaned:
    w_weekday = w['started'].weekday()
    if w_weekday != weekday:
        if totalSecondsDay is not None:
            print_logged_that_day(weekday, totalSecondsDay)
        totalSecondsDay = 0
        print_day(w_weekday, w['started'])
        weekday = w_weekday
    totalSeconds += w['timeSpentSeconds']
    totalSecondsDay += w['timeSpentSeconds']
    print()
    print(w['issue'])
    print("{}\t{}\t{}".format(w['started'].strftime("%H:%M"), w['timeSpent'], w['comment']))

if len(cleaned) > 0:
    print_logged_that_day(weekday, totalSecondsDay)

h, m = get_time_worked(totalSeconds)

print('Total time logged: {}h {}m'.format(h, m))
